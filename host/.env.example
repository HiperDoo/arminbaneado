# ============================================================
# Variables de entorno — Host Backend (main.py)
# ============================================================
# Estas variables van SOLO en el host, NUNCA en GitHub.
#
# IMPORTANTE: DISCORD_REDIRECT_URI debe apuntar a la página
# de GitHub Pages (NO al host). Así el usuario nunca vee ngrok.
# ============================================================

# Discord OAuth
DISCORD_CLIENT_ID=tu_client_id_aqui
DISCORD_CLIENT_SECRET=tu_client_secret_aqui   # ← NUNCA subir a GitHub
# redirect_uri apunta a GitHub Pages, NO al host
DISCORD_REDIRECT_URI=https://arminbaneado.com

# URLs
GITHUB_PAGES_URL=https://arminbaneado.com
HOST_URL=https://TU_NGROK.ngrok-free.app

# Servidor
PORT=3000
DATA_DIR=.
