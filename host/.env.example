# ============================================================
# Variables de entorno — Host Backend (main.py)
# ============================================================
# Copiar como .env y rellenar.
# Estas variables SE QUEDAN en el host, NUNCA en GitHub.
#
# GitHub Secrets (lo que va en GitHub):
#   HOST_URL          → URL pública de este host
#   DISCORD_CLIENT_ID → Client ID de Discord (es público)
#
# Esto que sigue va SOLO en el host:
# ============================================================

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=tu_client_id_aqui
DISCORD_CLIENT_SECRET=tu_client_secret_aqui   # ← NUNCA subir a GitHub
DISCORD_REDIRECT_URI=https://TU_HOST/api/firmar/callback

# URLs
GITHUB_PAGES_URL=https://santiagortegadev.github.io/baneodearmin
HOST_URL=https://TU_HOST

# Servidor
PORT=3000
DATA_DIR=.
