# ============================================================
# Variables de entorno — Resolución Caso Armin
# ============================================================
# Copiar este archivo como .env y rellenar los valores.
# En producción, estos valores se configuran como GitHub Secrets.
#
# GitHub Secrets (Settings → Secrets and variables → Actions):
#   DISCORD_CLIENT_ID
#   DISCORD_CLIENT_SECRET
#   DISCORD_REDIRECT_URI
#   DISCORD_BOT_TOKEN
#   DEPLOY_HOST
#   DEPLOY_USER
#   DEPLOY_SSH_KEY
#   DEPLOY_PATH
# ============================================================

# Discord OAuth — Crear app en https://discord.com/developers/applications
DISCORD_CLIENT_ID=tu_client_id_aqui
DISCORD_CLIENT_SECRET=tu_client_secret_aqui
DISCORD_REDIRECT_URI=http://localhost:3000/api/firmar/callback

# Discord Bot Token (opcional — para verificar miembros del servidor)
DISCORD_BOT_TOKEN=

# Servidor
PORT=3000

# Directorio donde se guardan los avatares descargados de Discord
AVATAR_DIR=./assets/avatars
